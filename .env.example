ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase ---
# SUPABASE_PROJECT_REF: found in your project URL → app.supabase.com/project/<REF>
# SUPABASE_ACCESS_TOKEN: supabase.com → Account → Access tokens → New token
# DATABASE_URL: Supabase → Settings → Database → URI (use "Session mode" port 5432)
# SUPABASE_JWT_SECRET: Settings → API → JWT Keys → Legacy JWT Secret tab (HS256)
# SUPABASE_URL: Settings → API → Project URL         (used by frontend SDK)
# SUPABASE_ANON_KEY: Settings → API → anon/public    (used by frontend SDK, safe to expose)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=sbp_...
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-legacy-jwt-secret
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJ...

# --- Ollama (optional) ---
# Set these to use a local model instead of Anthropic API for the executor.
# Install Ollama: https://ollama.com
#
# Intel Mac i7 16GB  →  ollama pull qwen2.5:7b
# Apple M4 Pro 24GB  →  ollama pull qwen2.5:32b
#
# QA_EXECUTOR_PROVIDER=ollama
# QA_EXECUTOR_MODEL=qwen2.5:7b        # Intel Mac
# QA_EXECUTOR_MODEL=qwen2.5:32b       # M4 Pro
# OLLAMA_BASE_URL=http://localhost:11434
